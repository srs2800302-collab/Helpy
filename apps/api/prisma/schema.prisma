generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobPaymentMethod {
  card
  cash
}

enum CommissionPayerRole {
  client
  master
}

enum SavedPaymentMethodStatus {
  active
  detached
  failed
  blocked
}

enum PaymentKind {
  deposit
  refund
}

enum PaymentSource {
  client_card
  master_card
}

enum PaymentStatus {
  pending
  requires_action
  paid
  failed
  refunded
}

model User {
  id        String   @id @default(cuid())
  phone     String?  @unique
  email     String?  @unique
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientJobs      Job[]            @relation("ClientJobs")
  paymentCustomer PaymentCustomer?
  paymentMethods  PaymentMethod[]
  payerPayments   Payment[]        @relation("PaymentPayerUser")
  masterProfile   MasterProfile?
}

model PaymentCustomer {
  id                 String   @id @default(cuid())
  userId             String   @unique
  provider           String
  providerCustomerId String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentMethods PaymentMethod[]

  @@index([provider, providerCustomerId])
}

model PaymentMethod {
  id                      String                   @id @default(cuid())
  userId                  String
  paymentCustomerId       String?
  provider                String
  providerPaymentMethodId String
  type                    String                   @default("card")
  brand                   String?
  last4                   String?
  expMonth                Int?
  expYear                 Int?
  isDefault               Boolean                  @default(false)
  status                  SavedPaymentMethodStatus @default(active)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentCustomer PaymentCustomer? @relation(fields: [paymentCustomerId], references: [id], onDelete: SetNull)
  payments        Payment[]

  @@index([userId, status])
  @@index([provider, providerPaymentMethodId])
}

model Job {
  id              String              @id @default(cuid())
  clientId        String
  title           String
  description     String?
  totalPrice      Decimal             @db.Decimal(12, 2)
  currency        String              @default("THB")
  status          String
  paymentMethod   JobPaymentMethod    @default(card)
  commissionPayer CommissionPayerRole
  depositPercent  Int                 @default(40)
  depositAmount   Decimal             @db.Decimal(12, 2)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  client   User      @relation("ClientJobs", fields: [clientId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([clientId, status])
  @@index([paymentMethod, status])
}

model Payment {
  id              String              @id @default(cuid())
  jobId           String
  payerUserId     String
  paymentMethodId String?
  provider        String
  providerRef     String?
  payerRole       CommissionPayerRole
  kind            PaymentKind
  source          PaymentSource
  status          PaymentStatus       @default(pending)
  amount          Decimal             @db.Decimal(12, 2)
  currency        String              @default("THB")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  job           Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  payerUser     User           @relation("PaymentPayerUser", fields: [payerUserId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)

  @@index([jobId, status])
  @@index([payerUserId, status])
  @@index([paymentMethodId])
}

model MasterProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  hasBillingMethod Boolean  @default(false)
  billingStatus    String   @default("missing")
  cashJobsEnabled  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
