generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  client
  master
  admin
}

enum OtpSessionStatus {
  pending
  verified
  expired
  cancelled
}

enum MasterVerificationStatus {
  pending
  approved
  rejected
  blocked
}

enum JobStatus {
  draft
  awaiting_payment
  open
  master_selected
  in_progress
  completed
  cancelled
  disputed
}

enum JobOfferStatus {
  active
  withdrawn
  accepted
  rejected
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
  cancelled
}

enum PaymentType {
  deposit
  refund
}

enum DisputeStatus {
  open
  in_review
  resolved
  rejected
}

model User {
  id                 String         @id @default(cuid())
  phone              String         @unique
  role               UserRole?
  isActive           Boolean        @default(true)
  isPhoneVerified    Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  clientProfile      ClientProfile?
  masterProfile      MasterProfile?
  otpSessions        OtpSession[]

  clientJobs         Job[]          @relation("ClientJobs")
  masterOffers       JobOffer[]     @relation("MasterOffers")
  sentMessages       ChatMessage[]  @relation("SenderMessages")
  clientReviews      Review[]       @relation("ClientReviews")
  masterReviews      Review[]       @relation("MasterReviews")
  openedDisputes     Dispute[]      @relation("OpenedDisputes")

  @@map("users")
}

model ClientProfile {
  id                 String    @id @default(cuid())
  userId             String    @unique
  firstName          String?
  lastName           String?
  displayName        String?
  photoUrl           String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user               User      @relation(fields: [userId], references: [id])

  @@map("client_profiles")
}

model MasterProfile {
  id                   String                     @id @default(cuid())
  userId               String                     @unique
  firstName            String?
  lastName             String?
  displayName          String?
  photoUrl             String?
  bio                  String?
  verificationStatus   MasterVerificationStatus   @default(pending)
  isAvailable          Boolean                    @default(true)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  user                 User                       @relation(fields: [userId], references: [id])
  categories           MasterCategory[]

  @@map("master_profiles")
}

model ServiceCategory {
  id                 String           @id @default(cuid())
  slug               String           @unique
  isActive           Boolean          @default(true)
  sortOrder          Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  masterCategories   MasterCategory[]
  jobs               Job[]

  @@map("service_categories")
}

model MasterCategory {
  id                 String           @id @default(cuid())
  masterProfileId    String
  categoryId         String
  createdAt          DateTime         @default(now())

  masterProfile      MasterProfile    @relation(fields: [masterProfileId], references: [id])
  category           ServiceCategory  @relation(fields: [categoryId], references: [id])

  @@unique([masterProfileId, categoryId])
  @@map("master_categories")
}

model Job {
  id                    String           @id @default(cuid())
  clientUserId          String
  categoryId            String
  title                 String
  description           String?
  addressText           String?
  locationLat           Decimal?         @db.Decimal(10, 7)
  locationLng           Decimal?         @db.Decimal(10, 7)
  status                JobStatus        @default(draft)
  selectedOfferId       String?          @unique
  selectedMasterUserId  String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  completedAt           DateTime?
  cancelledAt           DateTime?

  client                User             @relation("ClientJobs", fields: [clientUserId], references: [id])
  category              ServiceCategory  @relation(fields: [categoryId], references: [id])
  photos                JobPhoto[]
  offers                JobOffer[]
  messages              ChatMessage[]
  payments              Payment[]
  reviews               Review[]
  disputes              Dispute[]

  @@index([clientUserId, status])
  @@index([categoryId, status])
  @@index([selectedMasterUserId])
  @@map("jobs")
}

model JobPhoto {
  id                 String     @id @default(cuid())
  jobId              String
  url                String
  sortOrder          Int        @default(0)
  createdAt          DateTime   @default(now())

  job                Job        @relation(fields: [jobId], references: [id])

  @@map("job_photos")
}

model JobOffer {
  id                 String          @id @default(cuid())
  jobId              String
  masterUserId       String
  message            String?
  priceComment       String?
  status             JobOfferStatus  @default(active)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  job                Job             @relation(fields: [jobId], references: [id])
  master             User            @relation("MasterOffers", fields: [masterUserId], references: [id])

  @@unique([jobId, masterUserId])
  @@index([jobId, status])
  @@index([masterUserId, status])
  @@map("job_offers")
}

model ChatMessage {
  id                 String     @id @default(cuid())
  jobId              String
  senderUserId       String
  text               String
  createdAt          DateTime   @default(now())

  job                Job        @relation(fields: [jobId], references: [id])
  sender             User       @relation("SenderMessages", fields: [senderUserId], references: [id])

  @@index([jobId, createdAt])
  @@map("chat_messages")
}

model Payment {
  id                 String         @id @default(cuid())
  jobId              String
  userId             String
  type               PaymentType
  status             PaymentStatus  @default(pending)
  amount             Decimal        @db.Decimal(10, 2)
  currency           String         @default("THB")
  provider           String?
  providerRef        String?
  paidAt             DateTime?
  refundedAt         DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  job                Job            @relation(fields: [jobId], references: [id])

  @@index([jobId, status])
  @@index([userId, status])
  @@map("payments")
}

model Review {
  id                 String     @id @default(cuid())
  jobId              String
  clientUserId       String
  masterUserId       String
  rating             Int
  comment            String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  job                Job        @relation(fields: [jobId], references: [id])
  client             User       @relation("ClientReviews", fields: [clientUserId], references: [id])
  master             User       @relation("MasterReviews", fields: [masterUserId], references: [id])

  @@unique([jobId])
  @@index([masterUserId, rating])
  @@map("reviews")
}

model Dispute {
  id                 String         @id @default(cuid())
  jobId              String
  openedByUserId     String
  status             DisputeStatus  @default(open)
  reason             String
  resolutionNote     String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  resolvedAt         DateTime?

  job                Job            @relation(fields: [jobId], references: [id])
  openedBy           User           @relation("OpenedDisputes", fields: [openedByUserId], references: [id])

  @@index([jobId, status])
  @@map("disputes")
}

model OtpSession {
  id                 String            @id @default(cuid())
  phone              String
  code               String
  status             OtpSessionStatus  @default(pending)
  expiresAt          DateTime
  verifiedAt         DateTime?
  attemptsCount      Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  userId             String?

  user               User?             @relation(fields: [userId], references: [id])

  @@index([phone, status])
  @@index([expiresAt])
  @@map("otp_sessions")
}
